{
  "_comment": "패키지 그룹 정의 — Bootstrap DevEnv SSOT. 버전 변경 시 이 파일만 수정한다.",
  "_overridePlaceholders": {
    "{WINDOWS_SDK_VER}": "config/paths.ps1의 $Script:WINDOWS_SDK_VER 값으로 런타임 치환됨"
  },
  "groups": {
    "1": {
      "label": "Core (Git, Python 3.14, Node.js LTS, Rust, uv)",
      "default": true,
      "packages": [
        { "id": "Git.Git",            "name": "Git" },
        { "id": "Python.Python.3.14", "name": "Python 3.14" },
        { "id": "OpenJS.NodeJS.LTS",  "name": "Node.js LTS" },
        { "id": "Rustlang.Rustup",    "name": "Rust (rustup)" },
        { "id": "astral-sh.uv",       "name": "uv (Python pkg manager)" }
      ]
    },
    "2": {
      "label": "VS Build Tools 2022 (MSVC + Windows SDK)",
      "default": true,
      "packages": [
        {
          "id":       "Microsoft.VisualStudio.2022.BuildTools",
          "name":     "VS Build Tools 2022",
          "override": "--quiet --add Microsoft.VisualStudio.Workload.VCTools --add Microsoft.VisualStudio.Component.Windows11SDK.{WINDOWS_SDK_VER} --includeRecommended"
        }
      ]
    },
    "3": {
      "label": "Windows Terminal",
      "default": true,
      "packages": [
        { "id": "Microsoft.WindowsTerminal", "name": "Windows Terminal" }
      ]
    },
    "4": {
      "label": "Go",
      "default": false,
      "packages": [
        { "id": "GoLang.Go", "name": "Go" }
      ]
    },
    "5": {
      "label": "Java (Temurin JDK 17 LTS)",
      "default": false,
      "packages": [
        { "id": "EclipseAdoptium.Temurin.17.JDK", "name": "Temurin JDK 17" }
      ]
    },
    "6": {
      "label": "Android Studio",
      "default": false,
      "packages": [
        { "id": "Google.AndroidStudio", "name": "Android Studio" }
      ]
    },
    "7": {
      "label": "Docker Desktop",
      "default": false,
      "packages": [
        { "id": "Docker.DockerDesktop", "name": "Docker Desktop" }
      ]
    },
    "8": {
      "label": "Supabase CLI",
      "default": false,
      "packages": [
        { "id": "Supabase.CLI", "name": "Supabase CLI" }
      ]
    }
  }
}
