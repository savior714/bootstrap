{
  "metadata": {
    "name": "Antigravity Shared Policy",
    "version": "1.0.0",
    "description": "Cross-project standard for integrity and quality"
  },
  "file_integrity": {
    "encoding_rules": [
      {
        "description": "PowerShell 5.1 compatibility (Prevent parsing error)",
        "pattern": "**/*.ps1",
        "required_encoding": "UTF-8 with BOM"
      },
      {
        "description": "Windows Batch standard",
        "pattern": "**/*.{bat,cmd}",
        "required_encoding": "ANSI (CP949)"
      },
      {
        "description": "Modern web standard",
        "pattern": "**/*.{ts,js,json,md,yml,sql}",
        "required_encoding": "UTF-8 without BOM"
      }
    ],
    "refactoring_threshold": {
      "max_lines": 300,
      "action": "Plan Refactoring"
    }
  },
  "environment_integrity": {
    "required_binaries": [
      "node",
      "git",
      "pnpm",
      "tsc",
      "eslint",
      "prettier"
    ],
    "git_config": {
      "core.autocrlf": "true",
      "core.longpaths": "true"
    },
    "npm_config": {
      "registry": "https://registry.npmjs.org/"
    }
  },
  "lint_rules": {
    "eslint": {
      "no-console": "error",
      "semi": "always",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-debugger": "error"
    },
    "powershell": {
      "Strict-Mode": "Latest",
      "Avoid-Using-Bash-Commands": "true"
    }
  }
}
