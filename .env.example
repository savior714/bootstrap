# Bootstrap DevEnv — 환경 변수 예시 파일
# 이 파일을 복사하여 .env로 저장 후 값을 채우세요.
# .env는 .gitignore에 등록되어 절대 커밋되지 않습니다.
#
# 사용법:
#   Copy-Item .env.example .env
#   # .env 파일을 열어 필요한 값 수정
#   # bootstrap.bat 실행

# -------------------------------------------------------
# [선택] Java 설치 기준 경로
# Temurin JDK 설치 시 이 경로 아래에서 jdk-17* 폴더를 탐색합니다.
# 기본값: C:\Program Files\Eclipse Adoptium
# JAVA_INSTALL_BASE=C:\Program Files\Eclipse Adoptium

# -------------------------------------------------------
# [선택] Windows SDK 버전 (VS Build Tools Override 문자열에 사용)
# 기본값: 26100
# WINDOWS_SDK_VER=26100

# -------------------------------------------------------
# [선택] Winget 패키지 소스
# 기본값: winget
# WINGET_SOURCE=winget

# -------------------------------------------------------
# [선택] Antigravity Bootstrap 전역 경로
# 자동 등록되므로 수동 설정 불필요. 재정의가 필요한 경우에만 사용.
# ANTIGRAVITY_BOOTSTRAP_PATH=C:\develop\bootstrap
