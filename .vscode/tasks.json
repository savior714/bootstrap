{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TypeScript: Type Check (Full)",
      "type": "shell",
      "command": "npm run type-check",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": "$tsc",
      "detail": "tsc --noEmit 전체 실행. 에러는 Problems 패널에 표시됩니다."
    },
    {
      "label": "TypeScript: Errors Only (for LLM Context)",
      "type": "shell",
      "command": "npx -p typescript tsc --noEmit 2>&1 | findstr /R \"error TS\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "detail": "LLM에 전달할 최소 컨텍스트만 출력. 에러 라인만 필터링합니다."
    },
    {
      "label": "TypeScript: Watch Mode",
      "type": "shell",
      "command": "npm run type-check:watch",
      "isBackground": true,
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "base": "$tsc-watch",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting compilation",
          "endsPattern": "Found \\d+ error"
        }
      },
      "detail": "파일 변경 시 자동으로 타입 체크 실행 (백그라운드)."
    },
    {
      "label": "Validate: Type Check + Lint",
      "dependsOn": ["TypeScript: Type Check (Full)"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "npm run lint",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$eslint-stylish"],
      "detail": "타입 체크 → 린트 순서로 전체 유효성 검사 실행."
    }
  ]
}
